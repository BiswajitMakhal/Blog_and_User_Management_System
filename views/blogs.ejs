<%- include('./layouts/header') %>

    <div class="container mt-4">
        <%- include('./layouts/messages') %>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Latest Blogs</h2>
                <% if(user) { %>
                    <a href="/blogs/create" class="btn btn-success">Create Blog</a>
                    <% } %>
            </div>

            <div class="row">
                <% if(blogs && blogs.length> 0) { %>
                    <% blogs.forEach(blog=> { %>
                        <div class="col-md-4 mb-4">
                            <div class="card h-100 shadow-sm">
                                <% if(blog.image) { %>
                                    <img src="<%= blog.image %>" class="card-img-top" alt="Blog Image"
                                        style="height: 200px; object-fit: cover;">
                                    <% } else { %>
                                        <div class="card-img-top bg-secondary text-white d-flex align-items-center justify-content-center"
                                            style="height: 200px;">
                                            <span>No Image Available</span>
                                        </div>
                                        <% } %>

                                            <div class="card-body d-flex flex-column">
                                                <h5 class="card-title text-truncate">
                                                    <%= blog.title %>
                                                </h5>
                                                <p class="text-muted small mb-2">By: <%= blog.author.name %> | <%= new
                                                            Date(blog.createdAt).toLocaleDateString() %>
                                                </p>
                                                <p class="card-text text-truncate" style="max-height: 50px;">
                                                    <%= blog.content %>
                                                </p>

                                                <div class="mt-auto pt-3 border-top">
                                                    <a href="/blogs/<%= blog._id %>" class="btn btn-sm btn-primary">Read
                                                        More</a>

                                                    <% if(user && (user.id===blog.author._id.toString() ||
                                                        user.role==='Admin' )) { %>
                                                        <div class="float-end">
                                                            <a href="/blogs/edit/<%= blog._id %>"
                                                                class="btn btn-sm btn-outline-secondary">Edit</a>
                                                            <a href="/api/blogs/delete/<%= blog._id %>"
                                                                class="btn btn-sm btn-outline-danger"
                                                                onclick="return confirm('Are you sure you want to delete this blog?');">Delete</a>
                                                        </div>
                                                        <% } %>
                                                </div>
                                            </div>
                            </div>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div class="col-12 text-center">
                                    <h4 class="text-muted mt-5">No blogs found. Be the first to write one!</h4>
                                </div>
                                <% } %>
            </div>
    </div>

    <%- include('./layouts/footer') %>