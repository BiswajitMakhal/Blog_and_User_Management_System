<%- include('./layouts/header') %>

    <div class="container mt-4">
        <%- include('./layouts/messages') %>

            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="card shadow-sm">
                        <div class="card-header bg-warning text-dark">
                            <h4 class="mb-0">Edit Blog</h4>
                        </div>
                        <div class="card-body">
                            <form action="/api/blogs/update/<%= blog._id %>" method="POST"
                                enctype="multipart/form-data">
                                <div class="mb-3">
                                    <label class="form-label">Blog Title</label>
                                    <input type="text" class="form-control" name="title" value="<%= blog.title %>"
                                        required>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Update Cover Image (Leave blank to keep current)</label>
                                    <% if(blog.image) { %>
                                        <div class="mb-2">
                                            <img src="<%= blog.image %>" alt="Current Image" width="100"
                                                class="img-thumbnail">
                                        </div>
                                        <% } %>
                                            <input class="form-control" type="file" name="image" accept="image/*">
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Blog Content</label>
                                    <textarea class="form-control" name="content" rows="6"
                                        required><%= blog.content %></textarea>
                                </div>
                                <button type="submit" class="btn btn-warning w-100 fw-bold">Update Blog</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
    </div>

    <%- include('./layouts/footer') %>