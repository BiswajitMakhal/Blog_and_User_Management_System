<%- include('./layouts/header') %>

    <div class="container mt-4 mb-5">
        <%- include('./layouts/messages') %>

            <div class="row justify-content-center">
                <div class="col-md-10">
                    <div class="card shadow-sm border-0">
                        <% if(blog.image) { %>
                            <img src="<%= blog.image %>" class="card-img-top rounded-top" alt="Blog Image"
                                style="max-height: 400px; object-fit: cover;">
                            <% } %>
                                <div class="card-body p-5">
                                    <h1 class="card-title fw-bold">
                                        <%= blog.title %>
                                    </h1>
                                    <p class="text-muted">
                                        Written by <strong>
                                            <%= blog.author.name %>
                                        </strong> on <%= new Date(blog.createdAt).toLocaleDateString() %>
                                    </p>
                                    <hr>
                                    <div class="mt-4"
                                        style="white-space: pre-wrap; font-size: 1.1rem; line-height: 1.8;">
                                        <%= blog.content %>
                                    </div>
                                </div>
                                <div class="card-footer bg-white text-center py-3 border-top-0">
                                    <a href="/blogs" class="btn btn-outline-primary">&larr; Back to Blogs</a>
                                </div>
                    </div>
                </div>
            </div>
    </div>

    <%- include('./layouts/footer') %>